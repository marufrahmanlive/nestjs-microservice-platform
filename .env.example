# Environment
NODE_ENV=development

# API Gateway
GATEWAY_PORT=3000
GATEWAY_GLOBAL_PREFIX=api
GATEWAY_API_VERSION=v1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Microservices Ports
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
WS_PORT=3003
TODOS_SERVICE_PORT=3004
BOOKS_SERVICE_PORT=3005
POSTS_SERVICE_PORT=3006

# Database - MongoDB Atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/nestjs_db?retryWrites=true&w=majority
MONGO_DB_NAME=nestjs_db

# Cache - Redis
REDIS_URI=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Message Broker - RabbitMQ
RABBITMQ_URI=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=app.events
RABBITMQ_QUEUE_NOTIFICATIONS=notification.queue

# JWT Auth
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars-long-change-in-prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-long-change-in-prod
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Security
BCRYPT_ROUNDS=12
COOKIE_SECRET=your-cookie-secret-min-16-chars

# Email - SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=MyApp
SMTP_FROM_EMAIL=noreply@myapp.com

# Firebase - Push Notifications (FCM)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Twilio - SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Logging
LOG_LEVEL=debug
